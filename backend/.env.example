# ============================================================
# CipherSQLStudio Backend - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:5173

# MongoDB Atlas (Persistence DB - Assignments, Progress)
# Get free tier at: https://www.mongodb.com/cloud/atlas/register
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ciphersqlstudio?retryWrites=true&w=majority

# PostgreSQL (Neon.tech - Sandbox Query Execution)
# Get free tier at: https://neon.tech
DATABASE_URL=postgresql://<username>:<password>@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Google Gemini AI (Hint Generation - FREE)
# Get your API key at: https://makersuite.google.com/app/apikey
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
# Keep this false in production to ensure hints are generated by Gemini only
ALLOW_HINT_FALLBACK=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
